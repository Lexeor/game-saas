# Google OAuth Client ID
# Get it from https://console.cloud.google.com/ → APIs & Services → Credentials
# Allowed origins must include your dev URL (e.g. http://localhost:5173)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Backend API base URL (no trailing slash)
# The app will call: POST ${VITE_API_URL}/api/auth/google and POST ${VITE_API_URL}/api/auth/logout
VITE_API_URL=http://localhost:3000
